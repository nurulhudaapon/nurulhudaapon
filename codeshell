#!/bin/bash

# Define the templates directory
TEMPLATES_DIR="templates"

# Define function to display main menu
display_menu() {
    echo "Select an option:"
    echo "1. Create a new C program"
    echo "2. Build and run selected program"
    echo "3. Add a new template"
    echo "4. Add a new online template"
    echo "5. View code statistics"
    echo "6. Exit"
}

# Define function to create a new C program
create_c_program() {
    # Display available templates
    echo "Available templates:"
    templates=($TEMPLATES_DIR/*.c)
    for i in "${!templates[@]}"; do
        echo "$((i + 1)). ${templates[$i]##*/}"
    done
    echo "$(( ${#templates[@]} + 1 )). Back to main menu"

    read -p "Enter your choice: " choice

    if [ $choice -le ${#templates[@]} ] && [ $choice -gt 0 ]; then
        template_file=${templates[$((choice - 1))]}
    elif [ $choice -eq $(( ${#templates[@]} + 1 )) ]; then
        return
    else
        echo "Invalid choice. Please try again."
        return
    fi

    # Define the filename for the new C program
    read -p "Enter the filename for your C program (without extension): " filename

    # Check if the selected template exists
    if [ ! -f $template_file ]; then
        echo "Template file not found. Exiting."
        exit 1
    fi

    # Create a new C program file from the selected template
    cp $template_file "$filename.c"

    # Open the new C program file in Vim
    vim "$filename.c"
}

# Define function to build and run selected program
build_and_run_program() {
    read -p "Enter the filename of the program you want to build and run (without extension): " program_name

    # Check if the source file exists
    if [ ! -f "$program_name.c" ]; then
        echo "Source file '$program_name.c' not found."
        return
    fi

    # Compile the program
    gcc "$program_name.c" -o "$program_name"

    # Check if compilation was successful
    if [ $? -eq 0 ]; then
        # Run the program
        "./$program_name"
    else
        echo "Compilation failed."
    fi
}

# Define function to add a new template
add_new_template() {
    read -p "Enter the filename for the new template (without extension): " template_name
    new_template="$TEMPLATES_DIR/$template_name.c"

    # Check if the template already exists
    if [ -f $new_template ]; then
        echo "Template already exists."
        return
    fi

    # Create a new template file
    touch $new_template

    # Open the new template file in Vim
    vim $new_template

    echo "Template $template_name created successfully."
}

add_new_online_template() {
    read -p "Enter the URL of the online template: " template_url
    read -p "Enter the filename for the new template (without extension): " template_name
    new_template="$TEMPLATES_DIR/$template_name.c"

    # Check if the template already exists
    if [ -f $new_template ]; then
        echo "Template already exists."
        return
    fi

    # Download the online template
    curl -o $new_template $template_url

    # Open the new template file in Vim
    vim $new_template

    echo "Template $template_name created successfully."
}

# Define function to view code statistics
view_code_statistics() {
    read -p "Enter the filename of the program to view statistics (without extension): " program_name

    # Check if the source file exists
    if [ ! -f "$program_name.c" ]; then
        echo "Source file '$program_name.c' not found."
        return
    fi

    # Display code statistics
    echo "Statistics for $program_name.c:"
    echo "Line count: $(wc -l < "$program_name.c")"
    echo "Word count: $(wc -w < "$program_name.c")"
    echo "Character count: $(wc -m < "$program_name.c")"
}

# Main loop
while true; do
    display_menu
    read -p "Enter your choice: " main_choice

    case $main_choice in
        1) create_c_program ;;
        2) build_and_run_program ;;
        3) add_new_template ;;
        4) add_new_online_template ;;
        5) view_code_statistics ;;
        6) echo "Exiting."; exit ;;
        *) echo "Invalid choice. Please try again." ;;
    esac
done
